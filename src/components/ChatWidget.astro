---
import BrandMark from './BrandMark.astro';
---
<div id="chat-widget" class="chat-widget" hidden>
  <div class="chat-header">
    <BrandMark width={16} height={20} />
    <div class="chat-title">
      <div class="chat-name">HELLFIRE AGENT</div>
      <div class="chat-status">LIVE &mdash; THIS IS THE PRODUCT</div>
    </div>
    <button id="chat-close" aria-label="Close chat" class="chat-close">&times;</button>
  </div>
  <div id="chat-messages" class="chat-messages"></div>
  <div id="chat-typing" class="chat-typing" style="display:none">TYPING&hellip;</div>
  <div class="chat-input-row">
    <input id="chat-input" placeholder="Ask about modules, pricing, timelines&hellip;" class="chat-input" />
    <button id="chat-send" class="chat-send">SEND</button>
  </div>
</div>

<style>
  .chat-widget {
    position: fixed;
    right: 16px;
    bottom: 16px;
    z-index: 100;
    width: min(380px, calc(100vw - 32px));
    height: min(480px, calc(100vh - 100px));
    display: flex;
    flex-direction: column;
    background: rgba(250, 250, 248, 0.94);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(20, 20, 20, 0.15);
    box-shadow: 0 24px 64px rgba(20, 20, 20, 0.18);
  }
  .chat-widget[hidden] { display: none; }
  .chat-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--hairline);
  }
  .chat-title { flex: 1; }
  .chat-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.1em;
  }
  .chat-status {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--muted);
  }
  .chat-close {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
    color: var(--muted);
    padding: 4px;
  }
  .chat-close:hover { color: var(--ink); }
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  :global(.chat-bubble) {
    max-width: 85%;
    padding: 10px 14px;
    font-size: 14px;
    line-height: 1.5;
    white-space: pre-wrap;
  }
  .chat-typing {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--muted);
    border: 1px solid var(--hairline);
    padding: 10px 14px;
    margin: 0 16px 10px;
    align-self: flex-start;
  }
  .chat-input-row {
    display: flex;
    border-top: 1px solid var(--hairline);
  }
  .chat-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    padding: 14px 16px;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--ink);
  }
  .chat-send {
    border: none;
    cursor: pointer;
    background: var(--gold);
    color: var(--ink);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.08em;
    padding: 0 20px;
  }
  .chat-send:hover { background: var(--ink); color: var(--bg); }
</style>

<script>
  import { createChatController } from '../scripts/chat.js';

  const widget = document.getElementById('chat-widget') as HTMLElement;
  const openBtn = document.getElementById('open-chat');
  const closeBtn = document.getElementById('chat-close');

  openBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    widget.hidden = false;
  });
  closeBtn?.addEventListener('click', () => {
    widget.hidden = true;
  });

  createChatController({
    messagesEl: document.getElementById('chat-messages') as HTMLElement,
    typingEl: document.getElementById('chat-typing') as HTMLElement,
    inputEl: document.getElementById('chat-input') as HTMLInputElement,
    sendBtn: document.getElementById('chat-send') as HTMLButtonElement,
    theme: 'light',
  });
</script>
