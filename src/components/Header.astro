---
import BrandMark from './BrandMark.astro';

interface Props {
  variant?: 'full' | 'back';
  maxWidth?: string;
}
const { variant = 'full', maxWidth = '1200px' } = Astro.props;
---
<header class="site-header">
  <div class="header-inner" style={`max-width:${maxWidth}`}>
    <a href="/" class="brand">
      <BrandMark />
      <span class="wordmark">HELLFIRE</span>
    </a>
    {variant === 'full' ? (
      <nav class="nav-full">
        <a href="#what">What we do</a>
        <a href="#trust">Trust</a>
        <a href="/communicator">Contacts</a>
        <a class="btn-message" id="open-chat" href="#">Message us</a>
      </nav>
    ) : (
      <nav class="nav-back">
        <a href="/">&larr; Back to site</a>
      </nav>
    )}
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(250, 250, 248, 0.55);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--hairline);
  }
  .header-inner {
    margin: 0 auto;
    padding: 0 24px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .wordmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.18em;
  }
  .nav-full, .nav-back {
    display: flex;
    align-items: center;
    gap: clamp(14px, 3vw, 28px);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .nav-full a, .nav-back a {
    color: var(--muted);
  }
  .nav-full a:hover, .nav-back a:hover {
    color: var(--ink);
  }
  .btn-message {
    cursor: pointer;
    background: var(--gold);
    color: var(--ink) !important;
    border: 1px solid var(--gold);
    padding: 8px 14px;
    font-weight: 500;
  }
  .btn-message:hover {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--bg) !important;
  }
</style>
