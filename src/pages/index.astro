---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ChatWidget from '../components/ChatWidget.astro';
import GithubIcon from '../components/GithubIcon.astro';

const githubBase = 'https://github.com/HELLFIRE-Solutions';

const modules = [
  { num: 'M-01', name: 'Office agent', slug: 'office-agent', desc: 'Email, document workflows, internal knowledge base.' },
  { num: 'M-02', name: 'Sales / GTM agent', slug: 'gtm-agent', desc: 'Lead qualification, outbound, sales support.' },
  { num: 'M-03', name: 'RAG kit', slug: 'rag-01', desc: "Search and answers grounded in the company's private data." },
  { num: 'M-04', name: 'Agentic-Web Tag', slug: 'uni-tag', desc: 'Makes your site and catalog visible to other AI agents.' },
  { num: 'M-05', name: 'MCP server', slug: 'mcp-dev', desc: 'Connects your systems into agentic infrastructure.' },
  { num: 'M-06', name: 'In-house LLM', slug: 'inhouse-llm', desc: 'A closed model inside the company — for sensitive data.' },
  { num: 'M-07', name: 'Custom architecture', slug: '', desc: 'Anything beyond the standard catalog — built to order.' },
];

const segments = [
  { num: 'S-01', name: 'E-commerce / retail', desc: "Mid-sized businesses that haven't implemented AI yet — and already feel the pressure from competitors who have." },
  { num: 'S-02', name: 'Tour operators & travel', desc: 'Small and mid-sized agencies that need a client-facing booking agent without third-party platforms.' },
  { num: 'S-03', name: 'Compliance-first companies', desc: "Where GDPR / AI Act compliance isn't a nice-to-have but a requirement of any vendor." },
];
---
<Layout
  title="HELLFIRE AI Solutions — AI-agent implementation for mid-market business"
  description="Fast, trusted AI-agent implementation for mid-market business. Ready-to-deploy AI modules and AI-engineering outstaffing, DACH-first."
  path="/"
>
  <div class="page">
    <Header variant="full" />

    <section id="top" class="hero">
      <svg class="hero-watermark" viewBox="-60 -60 520 640" aria-hidden="true">
        <g fill="none" stroke="#141414" stroke-width="2" transform="translate(-34,-30)">
          <polygon points="40,40 110,90 110,440 40,380"></polygon>
          <polygon points="360,40 290,90 290,440 360,380"></polygon>
          <polygon points="168,200 200,160 232,200 232,470 200,520 168,470"></polygon>
          <polygon points="110,250 168,270 168,320 110,300"></polygon>
          <polygon points="290,250 232,270 232,320 290,300"></polygon>
        </g>
        <g fill="#141414">
          <polygon points="40,40 110,90 110,440 40,380"></polygon>
          <polygon points="360,40 290,90 290,440 360,380"></polygon>
          <polygon points="168,200 200,160 232,200 232,470 200,520 168,470"></polygon>
          <polygon points="110,250 168,270 168,320 110,300"></polygon>
          <polygon points="290,250 232,270 232,320 290,300"></polygon>
        </g>
        <g stroke="#FAFAF8" stroke-width="3">
          <line x1="75" y1="65" x2="75" y2="410"></line>
          <line x1="325" y1="65" x2="325" y2="410"></line>
          <line x1="200" y1="160" x2="200" y2="520"></line>
        </g>
      </svg>
      <div class="hero-inner">
        <div class="eyebrow">AI INFRASTRUCTURE, NOT EXPERIMENTS</div>
        <h1>We install an AI department into your business.</h1>
        <p class="hero-lead">
          Agents that handle your email, sales, and documents. Engineers who set them up and stay on
          your team. More revenue, less overhead — with someone accountable for both.
        </p>
        <div class="hero-actions">
          <a href="#contact" class="btn-gold">BOOK A CALL</a>
          <a href="#what" class="link-underline">SEE THE TWO PATHS &darr;</a>
        </div>
      </div>
    </section>

    <section class="gap-section">
      <div class="section-inner">
        <div class="section-label">01 &mdash; THE GAP</div>
        <div class="gap-grid">
          <div class="gap-cell">
            <div class="gap-tag">WITHOUT IMPLEMENTATION</div>
            <h2>"We want AI" stays a slide.</h2>
            <p>
              Pilots that never ship. Toy SaaS products serious companies reject. Enterprise
              consulting priced for the Fortune 500. The mid-market is left without a real fit.
            </p>
          </div>
          <div class="gap-cell gap-cell--highlight">
            <div class="gap-tag gap-tag--gold">WITH HELLFIRE</div>
            <h2>An agent running inside your process.</h2>
            <p>
              Value appears the moment it's live. You get an accountable party who owns the outcome —
              not a subscription. Model choice is an implementation detail, not an ideology.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="what" class="what-section">
      <div class="section-inner">
        <div class="section-label">02 &mdash; WHAT WE DO</div>
        <h2 class="section-title">Two ways to work with us.</h2>
        <p class="section-lead">
          We install a ready-made AI agent into your business — or place our AI engineers on your
          team. Most clients combine both.
        </p>

        <div class="path-row">
          <span class="path-tag">PATH 1</span>
          <h3 class="path-title">Ready-to-deploy AI solutions</h3>
          <a href={githubBase} target="_blank" rel="noopener" class="view-github">VIEW ON GITHUB &rarr;</a>
        </div>
        <div class="modules-grid">
          {modules.map((m) => (
            <a href={m.slug ? `${githubBase}/${m.slug}` : githubBase} target="_blank" rel="noopener" class="module-card">
              <div class="module-num"><span class="dot"></span>{m.num}</div>
              <div class="module-name">{m.name}</div>
              <div class="module-desc">{m.desc}</div>
              <div class="module-repo">
                <GithubIcon />
                {m.slug || 'HELLFIRE-Solutions'}
              </div>
            </a>
          ))}
          <div class="module-card module-card--dashed">
            <div class="module-diamond">&#9671;</div>
            <div class="module-name module-name--muted">In development</div>
            <div class="module-desc">
              New modules ship as they prove themselves in real deployments. Need something that
              isn't here yet? <a href="#contact" class="tell-us">Tell us.</a>
            </div>
          </div>
        </div>

        <div class="path2-panel">
          <div class="path2-heading">
            <span class="path-tag path-tag--dark">PATH 2</span>
            <h3 class="path2-title">AI-engineering outstaffing</h3>
          </div>
          <p class="path2-lead">
            HELLFIRE is a dedicated outstaffing system for AI engineers, architects, and
            implementation specialists — each verified through public proof of work. Not hourly
            billing: a "hire a team member" format with a transparent contract and no hidden
            markups. Our team stays with you, permanently, in whatever form fits:
          </p>
          <div class="path2-grid">
            <div class="path2-cell">
              <div class="path2-cell-label">01 &mdash; ON-SITE</div>
              <div class="path2-cell-desc">A specialist embedded in your office, working as part of your team.</div>
            </div>
            <div class="path2-cell">
              <div class="path2-cell-label">02 &mdash; REMOTE</div>
              <div class="path2-cell-desc">The same engagement, without geographic limits — minimum, part-time, or full-time.</div>
            </div>
            <div class="path2-cell">
              <div class="path2-cell-label">03 &mdash; VIA OUR AI AGENT</div>
              <div class="path2-cell-desc">Continuous presence through the agent we install — with the team behind it on the line.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="trust" class="trust-section">
      <div class="section-inner trust-grid">
        <div>
          <div class="section-label">03 &mdash; PARTNERSHIP</div>
          <h2 class="trust-title">A new type of company.</h2>
        </div>
        <div class="trust-copy">
          <p>
            HELLFIRE isn't a closed firm — it's an open network. Anyone can become a partner
            through our partner-onboarding system: an engineer, an architect, an agency, a company.
          </p>
          <p class="muted">
            We describe this approach separately — how entry works, and why it's different from
            hiring.
          </p>
          <a href="#partners" class="link-underline link-underline--tight">HOW PARTNERSHIP WORKS &rarr;</a>
        </div>
      </div>
    </section>

    <section id="who" class="who-section">
      <div class="section-inner">
        <div class="section-label">04 &mdash; WHO IT'S FOR</div>
        <h2 class="section-title">First wave.</h2>
        <div class="segments-grid">
          {segments.map((s) => (
            <div class="segment-cell">
              <div class="module-num"><span class="dot"></span>{s.num}</div>
              <div class="segment-name">{s.name}</div>
              <div class="module-desc">{s.desc}</div>
            </div>
          ))}
        </div>
        <div class="regions-row">
          <div class="region-col">
            <div class="region-title">EUROPE &mdash; DE</div>
            <p class="module-desc">We work across Europe, with Germany as our base.</p>
          </div>
          <div class="region-col">
            <div class="region-title">US</div>
            <p class="module-desc">Remote engagements, no geographic limits.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="contact" class="cta-section">
      <div class="section-inner cta-grid">
        <div>
          <div class="section-label section-label--gold">05 &mdash; CONTACT</div>
          <h2 class="cta-title">The outcome has a name and a face. Meet them.</h2>
          <p class="cta-lead">
            When we reach out, that outreach is already an example of what we install. See it
            working before you commit to anything.
          </p>
          <a href="https://cal.com" target="_blank" rel="noopener" class="btn-gold">BOOK A CALL</a>
        </div>
        <img src="/images/logo-full.jpg" alt="HELLFIRE AI Solutions" class="cta-logo" />
      </div>
    </section>

    <ChatWidget />

    <Footer variant="full" />
  </div>
</Layout>

<style>
  .page { min-height: 100vh; }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.22em;
    color: var(--gold-dark);
    margin-bottom: 28px;
  }
  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(56px, 8vw, 96px) 24px;
  }
  .section-label {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.22em;
    color: var(--muted);
    margin-bottom: 16px;
  }
  .section-label--gold { color: var(--gold-dark); margin-bottom: 20px; }
  .section-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(26px, 3.4vw, 40px);
    margin: 0 0 12px;
  }
  .section-lead {
    color: var(--muted);
    line-height: 1.6;
    max-width: 56ch;
    margin: 0 0 48px;
  }

  /* Hero */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--hairline);
  }
  .hero-watermark {
    position: absolute;
    right: -60px;
    top: 20px;
    width: min(560px, 90vw);
    height: auto;
    opacity: 0.07;
    pointer-events: none;
  }
  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(72px, 12vw, 140px) 24px clamp(64px, 10vw, 120px);
    position: relative;
  }
  h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(34px, 5.6vw, 68px);
    line-height: 1.08;
    margin: 0;
    max-width: 16ch;
    letter-spacing: 0.01em;
  }
  .hero-lead {
    font-size: clamp(16px, 2vw, 19px);
    line-height: 1.6;
    color: var(--muted);
    max-width: 52ch;
    margin: 28px 0 40px;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
  }
  .btn-gold {
    display: inline-block;
    background: var(--gold);
    color: var(--ink);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    letter-spacing: 0.06em;
    padding: 16px 32px;
  }
  .btn-gold:hover { background: var(--ink); color: var(--bg); }
  .link-underline {
    display: inline-block;
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    padding: 16px 8px;
    border-bottom: 1px solid var(--hairline);
  }
  .link-underline:hover { color: var(--gold-dark); }
  .link-underline--tight {
    padding: 0 0 4px;
    border-bottom: 2px solid var(--gold);
    align-self: flex-start;
  }

  /* Gap section */
  .gap-section { border-bottom: 1px solid var(--hairline); background: var(--bg-alt); }
  .gap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1px;
    background: var(--hairline);
    border: 1px solid var(--hairline);
  }
  .gap-cell { background: var(--bg-alt); padding: clamp(28px, 4vw, 48px); }
  .gap-cell--highlight {
    background: rgba(250, 250, 248, 0.9);
    backdrop-filter: blur(8px);
    border-top: 3px solid var(--gold);
  }
  .gap-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--muted);
    margin-bottom: 18px;
  }
  .gap-tag--gold {
    display: inline-block;
    color: var(--ink);
    background: var(--gold);
    padding: 6px 10px;
  }
  .gap-cell h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(22px, 2.6vw, 30px);
    line-height: 1.2;
    margin: 0 0 16px;
  }
  .gap-cell p { line-height: 1.65; color: var(--muted); margin: 0; max-width: 44ch; }

  /* What we do */
  .what-section { border-bottom: 1px solid var(--hairline); }
  .path-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 20px;
  }
  .path-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--gold-dark);
  }
  .path-tag--dark { color: var(--gold); }
  .path-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    margin: 0;
  }
  .view-github {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--ink);
    border-bottom: 2px solid var(--gold);
    padding-bottom: 3px;
  }
  .view-github:hover { color: var(--gold-dark); }
  .modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 16px;
    margin-bottom: 56px;
  }
  .module-card {
    display: block;
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(10px);
    border: 1px solid var(--hairline);
    padding: 24px;
    color: var(--ink);
  }
  .module-card:hover { border-color: var(--gold); }
  .module-card--dashed {
    border: 1px dashed rgba(20, 20, 20, 0.2);
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: transparent;
  }
  .module-num {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.16em;
    color: var(--gold-dark);
    margin-bottom: 16px;
  }
  .dot { width: 8px; height: 8px; background: var(--gold); display: inline-block; }
  .module-diamond {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.16em;
    color: var(--gold-dark);
    margin-bottom: 16px;
  }
  .module-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 8px;
  }
  .module-name--muted { color: var(--muted); }
  .module-desc { font-size: 14px; line-height: 1.55; color: var(--muted); margin-bottom: 16px; }
  .tell-us { color: var(--gold-dark); border-bottom: 1px solid rgba(184, 134, 11, 0.4); }
  .tell-us:hover { color: var(--ink); }
  .module-repo {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--ink);
    padding: 8px 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--ink);
  }

  .path2-panel {
    background: var(--ink);
    color: var(--bg);
    border-top: 3px solid var(--gold);
    padding: clamp(28px, 4vw, 48px);
  }
  .path2-heading {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 16px;
  }
  .path2-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(20px, 2.4vw, 26px);
    margin: 0;
  }
  .path2-lead {
    line-height: 1.65;
    color: rgba(250, 250, 248, 0.7);
    margin: 0 0 32px;
    max-width: 60ch;
  }
  .path2-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1px;
    background: rgba(250, 250, 248, 0.15);
    border: 1px solid rgba(250, 250, 248, 0.15);
  }
  .path2-cell { background: var(--ink); padding: 20px 22px; }
  .path2-cell-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--gold);
    margin-bottom: 10px;
  }
  .path2-cell-desc { font-size: 14px; line-height: 1.55; color: rgba(250, 250, 248, 0.85); }

  /* Trust */
  .trust-section { border-bottom: 1px solid var(--hairline); background: var(--bg-alt); }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: clamp(24px, 4vw, 64px);
  }
  .trust-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(26px, 3.4vw, 40px);
    line-height: 1.15;
    margin: 0;
    max-width: 16ch;
  }
  .trust-copy {
    display: flex;
    flex-direction: column;
    gap: 28px;
    align-self: center;
  }
  .trust-copy p { line-height: 1.65; margin: 0; max-width: 52ch; }
  .trust-copy p.muted { color: var(--muted); }

  /* Who/where */
  .who-section { border-bottom: 1px solid var(--hairline); }
  .segments-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1px;
    background: var(--hairline);
    border: 1px solid var(--hairline);
    margin-bottom: 40px;
  }
  .segment-cell { background: var(--bg); padding: clamp(24px, 3vw, 36px); }
  .segment-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17px;
    margin-bottom: 10px;
  }
  .regions-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 24px;
  }
  .region-col { border-top: 2px solid var(--ink); padding-top: 16px; }
  .region-title {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    margin-bottom: 8px;
  }

  /* CTA */
  .cta-section { background: #000000; color: #FAFAF8; }
  .cta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 48px;
    align-items: center;
    padding-top: clamp(72px, 10vw, 128px);
    padding-bottom: clamp(72px, 10vw, 128px);
  }
  .cta-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(28px, 3.8vw, 46px);
    line-height: 1.12;
    margin: 0 0 20px;
    max-width: 18ch;
  }
  .cta-lead {
    line-height: 1.65;
    color: rgba(250, 250, 248, 0.65);
    margin: 0 0 36px;
    max-width: 48ch;
  }
  .cta-logo { width: min(340px, 70%); justify-self: center; display: block; }
</style>
