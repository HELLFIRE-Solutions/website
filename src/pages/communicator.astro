---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import GithubIcon from '../components/GithubIcon.astro';
---
<Layout
  title="Communicator — HELLFIRE AI Solutions"
  description="Every channel, one wall. Reach HELLFIRE AI Solutions by chat, email, call, or GitHub."
  path="/communicator"
>
  <div class="page">
    <Header variant="back" />

    <div class="comm-inner">
      <div class="comm-heading">
        <h1>Communicator.</h1>
        <div class="comm-eyebrow">EVERY CHANNEL &mdash; ONE WALL</div>
      </div>

      <div class="tile-grid">
        <div class="tile tile--chat">
          <div class="chat-header">
            <span class="dot"></span>
            <div class="chat-title">
              <div class="chat-name">AGENT &mdash; WRITE HERE</div>
              <div class="chat-status">LIVE &mdash; THIS IS THE PRODUCT</div>
            </div>
          </div>
          <div id="chat-messages" class="chat-messages"></div>
          <div id="chat-typing" class="chat-typing" style="display:none">TYPING&hellip;</div>
          <div class="chat-input-row">
            <input id="chat-input" placeholder="Ask about modules, pricing, timelines&hellip;" class="chat-input" />
            <button id="chat-send" class="chat-send">SEND</button>
          </div>
        </div>

        <a href="mailto:hello@hellfire.ai" class="tile tile--email">
          <div class="tile-label">01 &mdash; EMAIL</div>
          <div>
            <div class="tile-title">hello@hellfire.ai</div>
            <div class="tile-sub">Answer within one business day.</div>
          </div>
        </a>

        <a href="tel:+4930000000" class="tile tile--call">
          <div class="tile-label">02 &mdash; CALL</div>
          <div class="tile-title">+49 30 000 00 00</div>
        </a>

        <div class="tile tile--gold">
          <svg width="52" height="66" viewBox="0 0 400 520" aria-hidden="true">
            <g fill="#141414">
              <polygon points="40,40 110,90 110,440 40,380"></polygon>
              <polygon points="360,40 290,90 290,440 360,380"></polygon>
              <polygon points="168,200 200,160 232,200 232,470 200,520 168,470"></polygon>
              <polygon points="110,250 168,270 168,320 110,300"></polygon>
              <polygon points="290,250 232,270 232,320 290,300"></polygon>
            </g>
          </svg>
        </div>

        <a href="#" target="_blank" rel="noopener" class="tile tile--nostr">
          <div class="tile-label">03 &mdash; NOSTR</div>
          <div>
            <div class="tile-title">Our Nostr page</div>
            <div class="tile-sub">Decentralized channel.</div>
          </div>
        </a>

        <a href="#" class="tile tile--blog">
          <div class="tile-label">04 &mdash; BLOG</div>
          <div>
            <div class="tile-title">Read our communication</div>
            <div class="tile-sub">Deployments, engineering notes, field lessons.</div>
          </div>
        </a>

        <a href="https://github.com/HELLFIRE-Solutions" target="_blank" rel="noopener" class="tile tile--github">
          <div class="tile-label">05 &mdash; GITHUB</div>
          <GithubIcon width={26} height={26} />
        </a>

        <a href="/#contact" class="tile tile--meet">
          <div class="tile-label">06 &mdash; MEET</div>
          <div class="tile-title">Book a call &rarr;</div>
        </a>

        <div class="tile tile--hud">
          <div class="hud-label"><span class="dot"></span>SERVER</div>
          <div class="hud-rows">
            UPTIME &mdash; <span id="hud-uptime">99.98%</span><br />
            LATENCY &mdash; <span id="hud-latency">42MS</span><br />
            REGION &mdash; EU-CENTRAL
          </div>
        </div>

        <div class="tile tile--audit">
          <div class="tile-label">AI AUDIT &mdash; EU / US</div>
          <div class="audit-badges">
            <span class="badge">EU AI ACT &mdash; AUDITED</span>
            <span class="badge">GDPR &mdash; COMPLIANT</span>
            <span class="badge badge--muted">SOC 2 TYPE II</span>
            <span class="badge badge--muted">CCPA &mdash; US</span>
          </div>
        </div>

        <div class="tile tile--status">
          <span class="status-item"><span class="dot"></span>AGENT &mdash; ONLINE</span>
          <span>TEAM &mdash; BERLIN &middot; LA</span>
          <span class="status-muted">RESPONSE &lt; 24H</span>
        </div>
      </div>
    </div>

    <Footer variant="simple" maxWidth="1200px" />
  </div>
</Layout>

<style>
  .page { min-height: 100vh; display: flex; flex-direction: column; }
  .comm-inner {
    flex: 1;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: clamp(32px, 5vw, 56px) 24px 64px;
    box-sizing: border-box;
  }
  .comm-heading {
    margin-bottom: clamp(28px, 4vw, 44px);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 16px 32px;
  }
  .comm-heading h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(26px, 3.6vw, 40px);
    line-height: 1.12;
    margin: 0;
  }
  .comm-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.22em;
    color: var(--gold-dark);
  }

  .tile-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    grid-auto-rows: 170px;
    grid-auto-flow: dense;
    gap: 1px;
    background: rgba(20, 20, 20, 0.12);
    border: 1px solid rgba(20, 20, 20, 0.12);
  }
  .tile { padding: 20px; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; color: var(--ink); }
  a.tile { background: var(--bg); }
  a.tile:hover { background: var(--bg-alt); }
  .tile-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--gold-dark);
  }
  .tile-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 4px;
    overflow-wrap: anywhere;
  }
  .tile-sub { font-size: 13px; color: var(--muted); }
  .dot { width: 8px; height: 8px; background: var(--gold); display: inline-block; }

  .tile--chat {
    grid-column: span 2;
    grid-row: span 3;
    background: var(--ink);
    color: var(--bg);
    padding: 0;
  }
  .chat-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--hairline-dark);
  }
  .chat-title { flex: 1; min-width: 0; }
  .chat-name { font-family: var(--font-display); font-weight: 600; font-size: 13px; letter-spacing: 0.1em; }
  .chat-status { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; color: rgba(250, 250, 248, 0.5); }
  .chat-messages { flex: 1; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 8px; }
  :global(.chat-bubble) { max-width: 88%; padding: 9px 12px; font-size: 13px; line-height: 1.5; white-space: pre-wrap; }
  .chat-typing {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: rgba(250, 250, 248, 0.5);
    border: 1px solid rgba(250, 250, 248, 0.15);
    padding: 8px 12px;
    margin: 0 14px 8px;
    align-self: flex-start;
  }
  .chat-input-row { display: flex; border-top: 1px solid var(--hairline-dark); }
  .chat-input {
    flex: 1;
    min-width: 0;
    border: none;
    outline: none;
    background: transparent;
    padding: 13px 14px;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--bg);
  }
  .chat-send {
    border: none;
    cursor: pointer;
    background: var(--gold);
    color: var(--ink);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.08em;
    padding: 0 18px;
  }
  .chat-send:hover { background: var(--bg); }

  .tile--email { grid-column: span 2; }
  .tile--gold { background: var(--gold); align-items: center; justify-content: center; }
  .tile--hud, .tile--status { background: var(--ink); color: var(--bg); }
  .tile--blog { grid-column: span 2; }

  .hud-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--gold);
  }
  .hud-rows {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    line-height: 2;
    color: rgba(250, 250, 248, 0.85);
  }

  .tile--audit { grid-column: 2 / -1; background: var(--bg); gap: 12px; }
  .audit-badges { display: flex; flex-wrap: wrap; gap: 8px; }
  .badge {
    border: 1px solid var(--ink);
    padding: 7px 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    white-space: nowrap;
  }
  .badge--muted { border-color: rgba(20, 20, 20, 0.3); color: var(--muted); }

  .tile--status {
    grid-column: 1 / -1;
    background: var(--bg-alt);
    color: var(--ink);
    flex-direction: row;
    flex-wrap: wrap;
    gap: 8px 32px;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
  }
  .status-item { display: flex; align-items: center; gap: 8px; }
  .status-muted { color: var(--muted); }
</style>

<script>
  import { createChatController } from '../scripts/chat.js';

  createChatController({
    messagesEl: document.getElementById('chat-messages') as HTMLElement,
    typingEl: document.getElementById('chat-typing') as HTMLElement,
    inputEl: document.getElementById('chat-input') as HTMLInputElement,
    sendBtn: document.getElementById('chat-send') as HTMLButtonElement,
    theme: 'dark',
  });

  const latencyEl = document.getElementById('hud-latency') as HTMLElement;
  setInterval(() => {
    const ms = 38 + Math.floor(Math.random() * 14);
    latencyEl.textContent = `${ms}MS`;
  }, 3000);
</script>
